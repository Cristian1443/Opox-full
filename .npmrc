# Config de pnpm para monorepo Expo.
# Expo y React Native asumen un layout plano de node_modules (como npm/yarn),
# no la estructura aislada que pnpm usa por defecto. Sin esto, deps como
# @babel/runtime (transitivas de react-native-web) no se resuelven y Metro
# revienta al bundlear con "Unable to resolve @babel/runtime/helpers/...".
#
# https://docs.expo.dev/guides/monorepos/ — sección "Additional Configuration"
node-linker=hoisted
public-hoist-pattern[]=*
shamefully-hoist=true
