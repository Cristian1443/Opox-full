    "typescript": "~6.0.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "dependencies": {
    "expo": "~57.0.1",
    "react": "19.2.3",
    "react-native": "0.86.0"
  }
}
