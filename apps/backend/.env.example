# ─────────────────────────────────────────────
# Servidor
# ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# CORS: orígenes permitidos separados por coma.
# En dev incluye la URL del bundler de Expo si consumes desde web.
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# ─────────────────────────────────────────────
# Supabase (crea el proyecto en https://supabase.com)
# ─────────────────────────────────────────────
# TODO: rellenar tras crear el proyecto en Supabase
#   1. Crear proyecto nuevo en https://app.supabase.com/
#   2. Project Settings → API → copiar Project URL y anon key
#   3. Project Settings → API → copiar service_role key (SOLO backend, nunca al mobile)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────
# API cliente (fuente de datos oficiales, temarios, BOE)
# ─────────────────────────────────────────────
# TODO: contratos por definir con el cliente
CLIENT_API_BASE_URL=
CLIENT_API_KEY=
CLIENT_API_TIMEOUT_MS=15000

# ─────────────────────────────────────────────
# API de IA (tutor, Foto-Test, generación de quizzes)
# ─────────────────────────────────────────────
# TODO: contratos por definir con el proveedor
AI_API_BASE_URL=
AI_API_KEY=
AI_API_DEFAULT_MODEL=
AI_API_TIMEOUT_MS=30000

# ─────────────────────────────────────────────
# RevenueCat (webhook de pagos y suscripciones)
# ─────────────────────────────────────────────
# TODO: crear cuenta en https://www.revenuecat.com/ y configurar webhook
REVENUECAT_WEBHOOK_SECRET=

# ─────────────────────────────────────────────
# Expo Push (notificaciones)
# ─────────────────────────────────────────────
# https://docs.expo.dev/push-notifications/sending-notifications/
EXPO_ACCESS_TOKEN=
